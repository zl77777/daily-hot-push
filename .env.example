# ========== AI 接口 ==========
# 选择: claude / openai / qwen(通义千问) / deepseek
AI_PROVIDER=deepseek
AI_API_KEY=your_api_key_here
AI_MODEL=deepseek-chat

# ========== 推送方式 ==========
# email / wechat
PUSH_MODE=email

# ========== 邮箱配置（QQ邮箱SMTP）==========
EMAIL_SENDER=your_qq@qq.com
EMAIL_RECEIVER=your_qq@qq.com
# QQ邮箱 SMTP 授权码（不是QQ密码！在QQ邮箱设置→账户→POP3/SMTP服务 里获取）
EMAIL_SMTP_CODE=your_smtp_code_here

# ========== 公众号（备用）==========
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# ========== NewsAPI ==========
NEWSAPI_KEY=your_newsapi_key

# ========== 天行数据(抖音热榜) ==========
TIANAPI_KEY=your_tianapi_key
