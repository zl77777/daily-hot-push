# ========== AI 接口 ==========
# 选择: claude / openai / qwen(通义千问) / deepseek
AI_PROVIDER=deepseek
AI_API_KEY=your_api_key_here
# Claude 模型: claude-sonnet-4-6 / claude-haiku-4-5
# OpenAI 模型: gpt-4o / gpt-4o-mini
# 千问模型: qwen-max / qwen-plus
# DeepSeek 模型: deepseek-chat
AI_MODEL=deepseek-chat

# ========== 公众号 ==========
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
# 订阅号填 mass，服务号填 template
WECHAT_PUSH_MODE=mass

# ========== NewsAPI ==========
NEWSAPI_KEY=your_newsapi_key

# ========== 天行数据(抖音热榜) ==========
# 注册 https://www.tianapi.com 获取
TIANAPI_KEY=your_tianapi_key

# ========== 每日推送时间 ==========
PUSH_HOUR=8
PUSH_MINUTE=30
